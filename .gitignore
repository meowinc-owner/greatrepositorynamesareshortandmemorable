# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
sharpshooter/.utmp/
sharpshooter/[Ll]ibrary/
sharpshooter/[Tt]emp/
sharpshooter/[Oo]bj/
sharpshooter/[Bb]uild/
sharpshooter/[Bb]uilds/
sharpshooter/[Ll]ogs/
sharpshooter/[Uu]ser[Ss]ettings/
sharpshooter/*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
sharpshooter/*.blend1
sharpshooter/*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
sharpshooter/[Mm]emoryCaptures/

# Recordings can get excessive in size
sharpshooter/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
sharpshooter/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
sharpshooter/*.DotSettings.user

# Visual Studio cache directory
sharpshooter/.vs/

# Gradle cache directory
sharpshooter/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
sharpshooter/ExportedObj/
sharpshooter/.consulo/
sharpshooter/*.csproj
sharpshooter/*.unityproj
sharpshooter/*.sln
sharpshooter/*.suo
sharpshooter/*.tmp
sharpshooter/*.user
sharpshooter/*.userprefs
sharpshooter/*.pidb
sharpshooter/*.booproj
sharpshooter/*.svd
sharpshooter/*.pdb
sharpshooter/*.mdb
sharpshooter/*.opendb
sharpshooter/*.VC.db

# Unity3D generated meta files
sharpshooter/*.pidb.meta
sharpshooter/*.pdb.meta
sharpshooter/*.mdb.meta

# Unity3D generated file on crash reports
sharpshooter/sysinfo.txt

# Mono auto generated files
sharpshooter/mono_crash.*

# Builds
sharpshooter/*.apk
sharpshooter/*.aab
sharpshooter/*.unitypackage
sharpshooter/*.unitypackage.meta
sharpshooter/*.app

# Crashlytics generated file
sharpshooter/crashlytics-build.properties

# TestRunner generated files
sharpshooter/InitTestScene*.unity*

# Addressables default ignores, before user customizations
sharpshooter/ServerData
sharpshooter/[Aa]ssets/StreamingAssets/aa*
sharpshooter/[Aa]ssets/AddressableAssetsData/link.xml*
sharpshooter/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
sharpshooter/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
sharpshooter/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
sharpshooter/ty.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
sharpshooter/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
sharpshooter/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
sharpshooter/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
